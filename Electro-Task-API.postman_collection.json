{
  "info": {
    "_postman_id": "simple-task-api-collection",
    "name": "simple Task API",
    "description": "RESTful Project & Task Management API.\n\n## Setup\n1. Import this collection into Postman.\n2. Run **Auth > Login (Member)** or **Login (Admin)** — the JWT is saved automatically.\n3. Use Projects and Tasks requests (IDs are auto-saved after create).\n\n## Seed users\n| Email | Password | Role |\n|-------|----------|------|\n| admin@example.com | Password123! | admin |\n| member@example.com | Password123! | member |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "host",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "b0000000-0000-4000-8000-000000000001",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "c0000000-0000-4000-8000-000000000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Public authentication endpoints. Login requests auto-save the JWT to `{{token}}`.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. Password must be 8+ chars with uppercase, lowercase, and a number."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "        console.log('Token saved from registration');",
                  "    }",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login (Member)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as seeded member user. Token is saved to collection variable `token`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "        console.log('Token saved:', json.data.token.substring(0, 20) + '...');",
                  "    }",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.token).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login (Admin)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as seeded admin user. Admin can access all projects."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "    }",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "description": "Project CRUD. Requires JWT. Members see only their projects; admins see all.",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Project\",\n  \"description\": \"Project description\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            },
            "description": "Create a new project. Status: active | completed | archived"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.id) {",
                  "        pm.collectionVariables.set('projectId', json.data.id);",
                  "        console.log('projectId saved:', json.data.id);",
                  "    }",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects?page=1&limit=10&sortBy=createdAt&sortOrder=DESC",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (default: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (max: 100)" },
                { "key": "sortBy", "value": "createdAt", "description": "title | status | createdAt | updatedAt" },
                { "key": "sortOrder", "value": "DESC", "description": "ASC | DESC" },
                { "key": "status", "value": "active", "description": "active | completed | archived", "disabled": true }
              ]
            },
            "description": "List projects with pagination and sorting."
          },
          "response": []
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "Get a single project. Uses `{{projectId}}` collection variable."
          },
          "response": []
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"description\": \"Updated description\",\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "Update project fields. At least one field required."
          },
          "response": []
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "Delete a project and all its tasks (cascade)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "Task CRUD nested under projects. Requires JWT.",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Task\",\n  \"description\": \"Task description\",\n  \"status\": \"pending\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-12-31T00:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "description": "Create a task under a project.\n\nStatus: pending | in_progress | done\nPriority: low | medium | high"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.id) {",
                  "        pm.collectionVariables.set('taskId', json.data.id);",
                  "        console.log('taskId saved:', json.data.id);",
                  "    }",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?page=1&limit=10&sortBy=createdAt&sortOrder=DESC",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "createdAt", "description": "title | status | priority | dueDate | createdAt | updatedAt" },
                { "key": "sortOrder", "value": "DESC" },
                { "key": "status", "value": "pending", "description": "pending | in_progress | done", "disabled": true },
                { "key": "priority", "value": "high", "description": "low | medium | high", "disabled": true }
              ]
            },
            "description": "List tasks for a project. Filter by status and/or priority."
          },
          "response": []
        },
        {
          "name": "Get Tasks - Filter by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=in_progress",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "status", "value": "in_progress" }
              ]
            },
            "description": "Filter tasks by status: pending | in_progress | done"
          },
          "response": []
        },
        {
          "name": "Get Tasks - Filter by Priority",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?priority=high",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "priority", "value": "high" }
              ]
            },
            "description": "Filter tasks by priority: low | medium | high"
          },
          "response": []
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            },
            "description": "Get a single task by ID."
          },
          "response": []
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"status\": \"in_progress\",\n  \"priority\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            },
            "description": "Update task fields including status and priority."
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            },
            "description": "Delete a task."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{host}}/health",
          "host": ["{{host}}"],
          "path": ["health"]
        },
        "description": "Public health check endpoint."
      },
      "response": []
    }
  ]
}
